set title 'Incidence ( 7 days )'
set xlabel 'transmission cycles'
set xrange [ 0.000000e+00 : 6.600000e+01 ]
set ylabel ' '
set format y '%10.1e'
set yrange [ 0.000000e+00 : 1.084281e-05 ]
set grid
set border
set key box
set pointsize 0.2
plot \
'7_days_incidence_R0=1.000' with lines
pause -1 '[ hit return to continue ]'
