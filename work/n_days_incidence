set title 'Cumulative incidence ( 7 days )'
set xlabel 'transmission cycles'
set xrange [ 0.000000e+00 : 7.300000e+02 ]
set ylabel 'per 100000'
set format y '%10.1e'
set yrange [ 0.000000e+00 : 1.500000e+04 ]
set grid
set border
set key box
set pointsize 0.2
plot \
'R=3.0_job1' with lines
pause -1 '[ hit return to continue ]'
replot \
'R=3.0_job2' with lines
pause -1 '[ hit return to continue ]'
