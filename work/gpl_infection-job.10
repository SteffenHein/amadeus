set title 'Herd infection [ sum of recovered, sick, asymptomatic, and lethal cases ]'
set xlabel 'transmission cycles'
set xrange [ 0.000000e+00 : 6.600000e+01 ]
set ylabel ' '
set format y '%10.1e'
set yrange [ 7.700000e-06 : 8.715882e-02 ]
set grid
set border
set key box
set pointsize 0.2
plot \
'h(t)_R0=1.125' with lines
pause -1 '[ hit return to continue ]'
