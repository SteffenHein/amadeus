set title 'Reproduction number'
set xlabel 'transmission cycles'
set xrange [ 0.000000e+00 : 6.600000e+01 ]
set ylabel 'reprod. no'
set format y '%10.1e'
set yrange [ 8.661573e-01 : 9.624904e-01 ]
set grid
set border
set key box
set pointsize 0.2
plot \
'r(t)_R0=.8750' with lines
pause -1 '[ hit return to continue ]'
