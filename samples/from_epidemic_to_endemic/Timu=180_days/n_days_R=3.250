set title 'Cumulative incidence ( 7 days )'
set xlabel 'days'
set xrange [ 0.000000e+00 : 1.095000e+03 ]
set ylabel 'per 100000'
set format y '%10.1e'
set yrange [ 0.000000e+00 : 2.200000e+04 ]
set grid
set border
set key box
set pointsize 0.2
plot \
'R=3.250_T=180d' with lines
pause -1 '[ hit return to continue ]'
replot \
'R=3.250_T=oo' with lines
pause -1 '[ hit return to continue ]'
