set title 'Cumulative incidence ( 7 days )'
set xlabel 'days'
set xrange [ 0.000000e+00 : 2.50000e+02 ]
set ylabel 'per 100000'
set format y '%10.1e'
set yrange [ 0.000000e+00 : 2.000000e+04 ]
set grid
set border
set key box
set pointsize 0.2
plot \
'R=3.000_T=180d' with lines
pause -1 '[ hit return to continue ]'
replot \
'R=3.000_T=oo' with lines
pause -1 '[ hit return to continue ]'
