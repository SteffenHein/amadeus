set title 'Cumulative incidence ( 7 days )'
set xlabel 'days'
set xrange [ 0.000000e+00 : 3.650000e+02 ]
set ylabel 'per 100000'
set format y '%10.1e'
set yrange [ 0.000000e+00 : 3.560390e+04 ]
set grid
set border
set key box
set pointsize 0.2
plot \
'7_days_incidence_R0=3.000' with lines
pause -1 '[ hit return to continue ]'
replot \
'7_days_incidence_R0=2.900' with lines
pause -1 '[ hit return to continue ]'
replot \
'7_days_incidence_R0=2.800' with lines
pause -1 '[ hit return to continue ]'
